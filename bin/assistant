#!/usr/bin/env node
'use strict';

const readline = require('readline');

const { AIClient }                           = require('../lib/ai');
const { VNCClient }                          = require('vnc-tool/lib/client');
const { loadConfig, saveConfig, CONFIG_FILE } = require('../lib/config');
const { Agent }                              = require('../lib/agent');

// ── ANSI helpers ──────────────────────────────────────────────────────────────

const C = {
  reset:  '\x1b[0m',
  bold:   '\x1b[1m',
  dim:    '\x1b[2m',
  green:  '\x1b[32m',
  red:    '\x1b[31m',
  yellow: '\x1b[33m',
  cyan:   '\x1b[36m',
};

const ok   = (s) => `${C.green}✓${C.reset} ${s}`;
const fail = (s) => `${C.red}✗${C.reset} ${s}`;
const info = (s) => `${C.cyan}→${C.reset} ${s}`;
const bold = (s) => `${C.bold}${s}${C.reset}`;
const dim  = (s) => `${C.dim}${s}${C.reset}`;

// ── Interactive prompt helpers ────────────────────────────────────────────────

/**
 * In non-TTY mode (piped input), stdin is pre-buffered upfront so that the
 * async gap between sequential rl.question() calls does not cause readline to
 * read ahead and discard answers meant for later prompts.
 */
let _pipedLines     = null;   // null = TTY / not yet initialised
let _pipedLineIndex = 0;

async function initStdin() {
  if (process.stdin.isTTY) return;   // real terminal — nothing to do
  if (_pipedLines !== null) return;  // already buffered
  return new Promise((resolve) => {
    const lines = [];
    const rl = readline.createInterface({ input: process.stdin, terminal: false });
    rl.on('line', (l) => lines.push(l));
    rl.on('close', () => { _pipedLines = lines; resolve(); });
  });
}

function closeRL() {
  // Nothing to close — readline interfaces are short-lived in TTY mode
  // and stdin is already consumed in piped mode.
}

/** Prompt for a line of input with an optional default value. */
function ask(question, defaultVal = '') {
  return new Promise((resolve) => {
    const label = defaultVal !== '' ? `${question} [${defaultVal}]: ` : `${question}: `;

    if (_pipedLines !== null) {
      // Piped / non-interactive mode: answer from pre-buffered lines.
      const raw    = (_pipedLineIndex < _pipedLines.length) ? _pipedLines[_pipedLineIndex++] : '';
      const answer = raw.trim() !== '' ? raw.trim() : defaultVal;
      process.stdout.write(`${label}${answer}\n`);
      resolve(answer);
      return;
    }

    // Interactive TTY mode.
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
    rl.question(label, (answer) => {
      rl.close();
      resolve(answer.trim() !== '' ? answer.trim() : defaultVal);
    });
  });
}

/** Prompt for a yes/no answer. */
async function askYesNo(question, defaultYes = true) {
  const hint   = defaultYes ? 'Y/n' : 'y/N';
  const answer = await ask(`${question} [${hint}]`);
  if (answer === '' || answer === (defaultYes ? 'Y/n' : 'y/N')) return defaultYes;
  return /^y/i.test(answer);
}

/**
 * Prompt for a secret value (password) without echoing typed characters.
 * Falls back to a visible prompt when stdin is not a TTY.
 */
function askSecret(question) {
  // In piped mode secrets are read the same as plain answers (no masking needed).
  if (_pipedLines !== null) return ask(question);

  return new Promise((resolve) => {
    const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
    let questionShown = false;
    rl._writeToOutput = (str) => {
      if (!questionShown) {
        process.stdout.write(str);
        questionShown = true;
      } else if (str === '\r\n' || str === '\n' || str === '\r') {
        process.stdout.write('\n');
      }
      // Suppress echoing of typed characters
    };
    rl.question(`${question}: `, (answer) => {
      rl.close();
      resolve(answer);
    });
  });
}

// ── Connection validators ─────────────────────────────────────────────────────

async function validateAI(aiConfig) {
  const ai = new AIClient(aiConfig);
  try {
    const reply = await ai.chat(
      [{ role: 'user', content: 'Reply with the single word: connected' }],
      { max_tokens: 20, temperature: 0 },
    );
    return { ok: true, response: (reply || '').trim().slice(0, 60) };
  } catch (e) {
    return { ok: false, error: e.message };
  }
}

async function validateVNC(vncConfig) {
  const vnc = new VNCClient(vncConfig);
  try {
    await vnc.connect();
    const width  = vnc.width;
    const height = vnc.height;
    await vnc.screenshot();
    await vnc.disconnect();
    return { ok: true, width, height };
  } catch (e) {
    return { ok: false, error: e.message };
  }
}

// ── Setup wizard ──────────────────────────────────────────────────────────────

async function setupWizard(existing) {
  // ── AI ────────────────────────────────────────────────────────────────────
  console.log();
  console.log(bold('── AI API ────────────────────────────────────'));

  const aiBaseUrl = await ask('API endpoint', existing?.ai?.baseUrl || 'http://localhost:11434/v1');
  const aiApiKey  = await askSecret('API key (blank for local models)');
  const aiModel   = await ask('Model name', existing?.ai?.model || 'llava');

  const aiConfig = {
    baseUrl: aiBaseUrl,
    apiKey:  aiApiKey || 'no-key',
    model:   aiModel,
  };

  process.stdout.write('Testing AI connection... ');
  const aiResult = await validateAI(aiConfig);
  if (aiResult.ok) {
    console.log(ok(`Connected  (model replied: "${aiResult.response}")`));
  } else {
    console.log(fail(`Failed: ${aiResult.error}`));
    if (!await askYesNo('Continue anyway?', false)) {
      throw new Error('Setup cancelled');
    }
  }

  // ── VNC ───────────────────────────────────────────────────────────────────
  console.log();
  console.log(bold('── VNC ───────────────────────────────────────'));

  const vncHost     = await ask('Device IP or hostname', existing?.vnc?.host || '');
  const vncPort     = parseInt(await ask('VNC port', String(existing?.vnc?.port || 5900)), 10);
  const vncPassword = await askSecret('VNC password (blank if none)');

  const vncConfig = {
    host:     vncHost,
    port:     vncPort,
    password: vncPassword || null,
  };

  process.stdout.write('Testing VNC connection... ');
  const vncResult = await validateVNC(vncConfig);
  if (vncResult.ok) {
    console.log(ok(`Connected  (${vncResult.width}×${vncResult.height})`));
  } else {
    console.log(fail(`Failed: ${vncResult.error}`));
    if (!await askYesNo('Continue anyway?', false)) {
      throw new Error('Setup cancelled');
    }
  }

  // ── Optional ──────────────────────────────────────────────────────────────
  console.log();
  console.log(bold('── Optional ──────────────────────────────────'));
  console.log(dim('(Used if the device shows a login screen before the desktop is visible)'));

  const lockPassword = await askSecret('Lock-screen password (blank to skip)');

  const config = {
    ai:           aiConfig,
    vnc:          vncConfig,
    lockPassword: lockPassword || '',
  };

  await saveConfig(config);
  console.log();
  console.log(ok(`Configuration saved to ${dim(CONFIG_FILE)}`));
  return config;
}

// ── Demo task ─────────────────────────────────────────────────────────────────

const DEMO_TASK = [
  'Change the desktop wallpaper to something different.',
  'First, look at the screenshot and identify the operating system.',
  'Then navigate to wallpaper settings using the appropriate method:',
  '  - macOS:        open System Settings → Wallpaper',
  '  - Windows:      right-click the desktop → Personalize → Background',
  '  - Linux/GNOME:  right-click the desktop → Change Background',
  'Once in the wallpaper settings, select any different wallpaper or solid color.',
  'Return {"done":true,"result":"<description of what you changed>"} when finished.',
].join(' ');

// ── Task runner ───────────────────────────────────────────────────────────────

/**
 * @param {object} config
 * @param {string} task
 * @param {object} [runOpts]
 * @param {number} [runOpts.maxSteps]
 * @param {string} [runOpts.label]
 * @param {number} [runOpts.verbose]        0=default 1=verbose 2=debug
 * @param {boolean}[runOpts.screenshots]    save PNGs to /tmp/
 */
async function runTask(config, task, { maxSteps = 15, label = 'Task', verbose = 0, screenshots = false, aiTimeout, maxImageWidth } = {}) {
  const agent = new Agent({
    vnc:           config.vnc,
    ai:            config.ai,
    maxSteps,
    verbose,
    screenshotDir: screenshots ? true : null,
    aiTimeout,
    maxImageWidth,
  });

  console.log();
  console.log(bold(`── ${label} ──────────────────────────────────`));
  console.log(dim(task.slice(0, 120) + (task.length > 120 ? '…' : '')));
  console.log();

  await agent.connect();
  try {
    const result = await agent.run(task, {
      onStep: (step, actions) => {
        // Build a compact step summary: show cmd + coords + reason for each action
        const summary = actions.map(a => {
          const coords = (a.x !== undefined && a.y !== undefined) ? ` (${a.x},${a.y})` : '';
          const reason = a.reason ? ` "${a.reason}"` : '';
          return `${a.cmd}${coords}${reason}`;
        }).join('; ');
        const preview = summary.length > 120 ? summary.slice(0, 120) + '…' : summary;
        console.log(info(`Step ${step}: ${preview}`));
      },
    });
    console.log();
    console.log(ok(`Done in ${result.steps} step(s): ${result.result}`));
    return result;
  } finally {
    await agent.disconnect();
  }
}

// ── Usage ─────────────────────────────────────────────────────────────────────

function printUsage() {
  console.log(`${bold('remote-device-ai-assistant')}

Usage: node bin/assistant [options]

Options:
  --setup           Re-run the setup wizard
  --task "TEXT"     Run a specific task using saved configuration
  --demo            Run the wallpaper-change demo
  --verbose, -v       Show AI response text and per-action intent
  --debug             Show full prompts + responses sent to/from the AI
  --screenshots       Save each step screenshot to /tmp/rda-<timestamp>/
  --ai-timeout N      AI request timeout in seconds (default: 300)
  --max-image-width N Downscale screenshots to this width before sending to AI
                      (default: 768; 0 to disable)
  --help              Show this message

Without options, the assistant checks for saved configuration and offers to run
the demo, prompting for setup if no configuration is found.

Configuration is stored in: ${dim(CONFIG_FILE)}
`);
}

// ── Main ──────────────────────────────────────────────────────────────────────

async function main() {
  await initStdin();

  const args        = process.argv.slice(2);
  const flags       = new Set(args.filter((a) => a.startsWith('--') || a.startsWith('-')));
  const verbose     = flags.has('--debug') ? 2 : (flags.has('--verbose') || flags.has('-v') ? 1 : 0);
  const screenshots = flags.has('--screenshots');

  // Parse --ai-timeout N (seconds) and --max-image-width N
  const aiTimeoutIdx    = args.indexOf('--ai-timeout');
  const aiTimeout       = aiTimeoutIdx !== -1 ? parseInt(args[aiTimeoutIdx + 1], 10) * 1000 : undefined;
  const maxImgWidthIdx  = args.indexOf('--max-image-width');
  const maxImageWidth   = maxImgWidthIdx !== -1 ? parseInt(args[maxImgWidthIdx + 1], 10) : undefined;

  if (flags.has('--help')) {
    printUsage();
    return;
  }

  console.log();
  console.log(bold('remote-device-ai-assistant'));
  console.log(dim('─'.repeat(40)));

  // --setup: force re-run wizard
  if (flags.has('--setup')) {
    const existing = await loadConfig();
    await setupWizard(existing);
    return;
  }

  // --task "TEXT": run a specific task
  const taskIdx = args.indexOf('--task');
  if (taskIdx !== -1) {
    const taskText = args[taskIdx + 1];
    if (!taskText || taskText.startsWith('--')) {
      console.error(fail('--task requires a task description in quotes'));
      process.exit(1);
    }
    const config = await loadConfig();
    if (!config) {
      console.error(fail('No saved configuration found. Run without arguments to set up.'));
      process.exit(1);
    }
    await runTask(config, taskText, { verbose, screenshots, aiTimeout, maxImageWidth });
    return;
  }

  // --demo: run the wallpaper demo
  if (flags.has('--demo')) {
    const config = await loadConfig();
    if (!config) {
      console.error(fail('No saved configuration found. Run without arguments to set up.'));
      process.exit(1);
    }
    await runTask(config, DEMO_TASK, { label: 'Demo: Change Wallpaper', maxSteps: 20, verbose, screenshots, aiTimeout, maxImageWidth });
    return;
  }

  // Interactive mode: check for existing config, offer to (re)run setup, then demo
  let config = await loadConfig();
  if (config) {
    console.log(ok(`Found configuration: ${config.vnc.host} / model: ${config.ai.model}`));
    const rerun = await askYesNo('Re-run setup wizard?', false);
    if (rerun) config = await setupWizard(config);
  } else {
    console.log(info('No configuration found. Starting setup wizard.'));
    config = await setupWizard(null);
  }

  const runDemo = await askYesNo('Run the wallpaper-change demo now?');
  closeRL();
  if (runDemo) {
    await runTask(config, DEMO_TASK, { label: 'Demo: Change Wallpaper', maxSteps: 20, verbose, screenshots, aiTimeout, maxImageWidth });
  }
}

main().catch((e) => {
  console.error(fail(e.message || String(e)));
  process.exit(1);
});
