{
  "name": "remote-device-ai-assistant",
  "version": "0.2.0",
  "description": "Minimal AI assistant for remote devices via VNC using any OpenAI-compatible API",
  "main": "lib/index.js",
  "bin": {
    "remote-assistant": "bin/assistant"
  },
  "scripts": {
    "test": "node --test test/ai.test.js test/agent.test.js test/prompts.test.js",
    "test:verbose": "node --test --reporter=spec test/ai.test.js test/agent.test.js test/prompts.test.js",
    "test:integration": "node --test test/integration.test.js",
    "test:compat": "node --test test/compat.test.js"
  },
  "engines": { "node": ">=18" },
  "dependencies": {
    "vnc-tool": "github:denisps/vnc-tool#semver:^0.3.0"
  },
  "license": "MIT"
}
